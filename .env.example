# ============================
# Configuracoes do Clube de Programacao
# ============================
# Copie este arquivo para .env e preencha com seus dados.
# Em producao (Vercel), configure estas variaveis no dashboard do projeto.

# --- Obrigatorio ---
SECRET_KEY=changeme
DEBUG=True
DATABASE_URL=sqlite:///db.sqlite3
# Para PostgreSQL (producao):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- Hosts ---
ALLOWED_HOSTS=localhost,127.0.0.1

# --- CSRF (producao) ---
# CSRF_TRUSTED_ORIGINS=https://seu-projeto.vercel.app

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=Clube de Programacao <noreply@clubedeprogramacao.com>

# --- Seguranca (producao) ---
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# SECURE_SSL_REDIRECT=False

# --- Pusher (Chat em tempo real) ---
# Crie uma conta gratuita em https://pusher.com e preencha:
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=sa1

# --- Cloudinary (Armazenamento de arquivos) ---
# Crie uma conta gratuita em https://cloudinary.com e preencha:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
